<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) usa estas reglas para definir qué se incluye en backups
  y transferencias D2D. NUESTRA POLÍTICA: NO incluir nada.

  La IndexedDB del POS contiene datos sensibles multi-tenant (ventas, clientes,
  hashes de PIN). Permitir backup vía `adb backup` o transferencia D2D permitiría
  exfiltrar todos los datos del negocio. Mejor que cada dispositivo re-sincronice
  desde Supabase (que tiene RLS y autenticación).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
        <exclude domain="file" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
        <exclude domain="file" />
    </device-transfer>
</data-extraction-rules>
